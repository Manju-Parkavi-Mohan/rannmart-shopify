{% doc %}
  @prompt
    Create a new section with a single row of 4 columns that auto-scrolls horizontally like a carousel/slider. The section should display products or content cards in 4 columns per row, with smooth infinite auto-scroll animation. Include controls to pause on hover and make it responsive for mobile devices.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-auto-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-auto-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
    padding: 0 20px;
  }

  .ai-auto-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
    font-weight: 700;
  }

  .ai-auto-carousel__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-auto-carousel__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-auto-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    animation: ai-auto-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-auto-carousel__track-{{ ai_gen_id }}.paused {
    animation-play-state: paused;
  }

  .ai-auto-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 3)) / 4);
    min-width: calc((100% - ({{ block.settings.card_gap }}px * 3)) / 4);
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-auto-carousel__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | times: 1.5 }});
  }

  .ai-auto-carousel__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-auto-carousel__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-auto-carousel__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-auto-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-auto-carousel__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-auto-carousel__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.card_text_color }};
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .ai-auto-carousel__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
    margin-bottom: 12px;
  }

  .ai-auto-carousel__product-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 16px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    transition: background-color 0.3s ease;
  }

  .ai-auto-carousel__product-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @keyframes ai-auto-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-100% - {{ block.settings.card_gap }}px));
    }
  }

  @media screen and (max-width: 989px) {
    .ai-auto-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 1)) / 2);
      min-width: calc((100% - ({{ block.settings.card_gap }}px * 1)) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-auto-carousel__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-auto-carousel__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-auto-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 0)) / 1);
      min-width: calc((100% - ({{ block.settings.card_gap }}px * 0)) / 1);
    }
  }
{% endstyle %}

<auto-carousel-{{ ai_gen_id }} class="ai-auto-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-auto-carousel__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-auto-carousel__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-auto-carousel__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-auto-carousel__track-wrapper-{{ ai_gen_id }}">
    <div class="ai-auto-carousel__track-{{ ai_gen_id }}" data-track>
      {% if block.settings.product_list != blank %}
        {% for product in block.settings.product_list %}
          <div class="ai-auto-carousel__card-{{ ai_gen_id }}">
            <div class="ai-auto-carousel__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-auto-carousel__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-auto-carousel__image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-auto-carousel__content-{{ ai_gen_id }}">
              <h3 class="ai-auto-carousel__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              <div class="ai-auto-carousel__product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
              <a href="{{ product.url }}" class="ai-auto-carousel__product-link-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        {% endfor %}

        {% for product in block.settings.product_list %}
          <div class="ai-auto-carousel__card-{{ ai_gen_id }}">
            <div class="ai-auto-carousel__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-auto-carousel__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-auto-carousel__image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-auto-carousel__content-{{ ai_gen_id }}">
              <h3 class="ai-auto-carousel__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              <div class="ai-auto-carousel__product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
              <a href="{{ product.url }}" class="ai-auto-carousel__product-link-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..8) %}
          <div class="ai-auto-carousel__card-{{ ai_gen_id }}">
            <div class="ai-auto-carousel__image-wrapper-{{ ai_gen_id }}">
              <div class="ai-auto-carousel__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="ai-auto-carousel__content-{{ ai_gen_id }}">
              <h3 class="ai-auto-carousel__product-title-{{ ai_gen_id }}">Product {{ i }}</h3>
              <div class="ai-auto-carousel__product-price-{{ ai_gen_id }}>$99.00</div>
              <a href="#" class="ai-auto-carousel__product-link-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</auto-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class AutoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.isPaused = false;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        
        if (this.track) {
          this.setupEventListeners();
        }
      }

      setupEventListeners() {
        {% if block.settings.pause_on_hover %}
          this.track.addEventListener('mouseenter', () => {
            this.track.classList.add('paused');
          });

          this.track.addEventListener('mouseleave', () => {
            this.track.classList.remove('paused');
          });
        {% endif %}
      }
    }

    customElements.define('auto-carousel-{{ ai_gen_id }}', AutoCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
