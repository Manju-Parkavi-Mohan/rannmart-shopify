{% doc %}
  @prompt
    Create a new section with a vertical auto-scrolling carousel that displays content cards in a single column, scrolling upward in a smooth infinite loop. Show 4 items visible at a time in one row layout. Include pause-on-hover functionality and make it responsive for mobile devices.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vertical-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
    position: relative;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.container_padding }}px;
  }

  .ai-vertical-carousel-track-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_gap }}px;
    animation: ai-vertical-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-vertical-carousel-{{ ai_gen_id }}:hover .ai-vertical-carousel-track-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  @keyframes ai-vertical-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  .ai-vertical-carousel-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    box-shadow: 0 {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    flex-shrink: 0;
  }

  .ai-vertical-carousel-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 {{ block.settings.card_shadow_vertical | plus: 4 }}px {{ block.settings.card_shadow_blur | plus: 4 }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | plus: 0.1 }});
  }

  .ai-vertical-carousel-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.card_image_height }}px;
    object-fit: cover;
    border-radius: {{ block.settings.card_image_radius }}px;
    margin-bottom: 12px;
  }

  .ai-vertical-carousel-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.card_image_height }}px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.card_image_radius }}px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-vertical-carousel-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-vertical-carousel-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .ai-vertical-carousel-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-vertical-carousel-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-vertical-carousel-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-vertical-carousel-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }

    .ai-vertical-carousel-card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<vertical-carousel-{{ ai_gen_id }} class="ai-vertical-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-vertical-carousel-track-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% liquid
        assign card_title_key = 'card_' | append: i | append: '_title'
        assign card_description_key = 'card_' | append: i | append: '_description'
        assign card_image_key = 'card_' | append: i | append: '_image'
        
        assign card_title = block.settings[card_title_key]
        assign card_description = block.settings[card_description_key]
        assign card_image = block.settings[card_image_key]
      %}

      <div class="ai-vertical-carousel-card-{{ ai_gen_id }}">
        {% if card_image %}
          <img
            src="{{ card_image | image_url: width: 600 }}"
            alt="{{ card_image.alt | escape }}"
            loading="lazy"
            width="600"
            height="{{ block.settings.card_image_height }}"
            class="ai-vertical-carousel-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-vertical-carousel-card-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if card_title != blank %}
          <h3 class="ai-vertical-carousel-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
        {% endif %}

        {% if card_description != blank %}
          <p class="ai-vertical-carousel-card-description-{{ ai_gen_id }}">{{ card_description }}</p>
        {% endif %}
      </div>
    {% endfor %}

    {% for i in (1..8) %}
      {% liquid
        assign card_title_key = 'card_' | append: i | append: '_title'
        assign card_description_key = 'card_' | append: i | append: '_description'
        assign card_image_key = 'card_' | append: i | append: '_image'
        
        assign card_title = block.settings[card_title_key]
        assign card_description = block.settings[card_description_key]
        assign card_image = block.settings[card_image_key]
      %}

      <div class="ai-vertical-carousel-card-{{ ai_gen_id }}">
        {% if card_image %}
          <img
            src="{{ card_image | image_url: width: 600 }}"
            alt="{{ card_image.alt | escape }}"
            loading="lazy"
            width="600"
            height="{{ block.settings.card_image_height }}"
            class="ai-vertical-carousel-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-vertical-carousel-card-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if card_title != blank %}
          <h3 class="ai-vertical-carousel-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
        {% endif %}

        {% if card_description != blank %}
          <p class="ai-vertical-carousel-card-description-{{ ai_gen_id }}">{{ card_description }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</vertical-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VerticalCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-vertical-carousel-track-{{ ai_gen_id }}');
        this.setupInfiniteScroll();
      }

      setupInfiniteScroll() {
        if (!this.track) return;

        this.addEventListener('mouseenter', () => {
          this.track.style.animationPlayState = 'paused';
        });

        this.addEventListener('mouseleave', () => {
          this.track.style.animationPlayState = 'running';
        });
      }
    }

    customElements.define('vertical-carousel-{{ ai_gen_id }}', VerticalCarousel{{ ai_gen_id }});
  })();
</script>

