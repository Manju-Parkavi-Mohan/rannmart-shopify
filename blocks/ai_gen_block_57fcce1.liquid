{% doc %}
  @prompt
    Create a product carousel section that displays products from a selected collection. Layout should be one row with one column visible at a time (single product focus). Include auto-scroll every 3-4 seconds with smooth transitions, left/right arrow navigation buttons, and dot indicators. Each slide shows a full product card with image, title, price, and an "Add to Cart" button. The section should have a collection picker setting in the theme editor so merchants can select which collection to display. Also include settings for: number of products to show, auto-scroll speed, and section heading text. Premium clean aesthetic suitable for car and bike accessories store.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-carousel__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-carousel__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 32px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    font-weight: 700;
  }

  .ai-product-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: 18px;
  }

  .ai-product-carousel__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-product-carousel__slide-{{ ai_gen_id }} {
    min-width: 100% !important;
    max-width: 100% !important;
    width: 100% !important;
    flex: 0 0 100% !important;
  }

  .ai-product-carousel__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: 18px;
    border: 1px solid {{ block.settings.card_border_color }};
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-product-carousel__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden !important;
    background-color: #f4f4f4;
  }

  .ai-product-carousel__image-{{ ai_gen_id }} {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }

  .ai-product-carousel__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-carousel__content-{{ ai_gen_id }} {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ai-product-carousel__title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 12px;
    color: {{ block.settings.text_color }};
    line-height: 1.4;
  }

  .ai-product-carousel__price-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 20px;
    color: {{ block.settings.price_color }};
  }

  .ai-product-carousel__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 40px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .ai-product-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-product-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-product-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
  }

  .ai-product-carousel__nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.arrow_color }};
  }

  .ai-product-carousel__nav--prev-{{ ai_gen_id }} {
    left: 16px;
  }

  .ai-product-carousel__nav--next-{{ ai_gen_id }} {
    right: 16px;
  }

  .ai-product-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
  }

  .ai-product-carousel__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
    opacity: 0.4;
  }

  .ai-product-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-product-carousel__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-carousel__nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-product-carousel__nav-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }

    .ai-product-carousel__nav--prev-{{ ai_gen_id }} {
      left: 8px;
    }

    .ai-product-carousel__nav--next-{{ ai_gen_id }} {
      right: 8px;
    }

    .ai-product-carousel__content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-product-carousel__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    
  }

{% endstyle %}


<product-carousel-{{ ai_gen_id }}
  class="ai-product-carousel-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-product-carousel__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.collection != blank and block.settings.collection.products.size > 0 %}
      {% assign products_to_show = block.settings.products_count | at_most: block.settings.collection.products.size %}

      <div class="ai-product-carousel__wrapper-{{ ai_gen_id }}">
        <div class="ai-product-carousel__track-{{ ai_gen_id }}">
          {% for product in block.settings.collection.products limit: products_to_show %}
            <div class="ai-product-carousel__slide-{{ ai_gen_id }}">
              <div class="ai-product-carousel__card-{{ ai_gen_id }}">
                <div class="ai-product-carousel__image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 800 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-product-carousel__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="800"
                      height="800"
                    >
                  {% else %}
                    <div class="ai-product-carousel__image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-product-carousel__content-{{ ai_gen_id }}">
                  <h3 class="ai-product-carousel__title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <div class="ai-product-carousel__price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                  <a
                    href="{{ product.url }}"
                    class="ai-product-carousel__button-{{ ai_gen_id }}"
                  >
                    {{ block.settings.button_text }}
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        {% if products_to_show > 1 %}
          <button
            class="ai-product-carousel__nav-{{ ai_gen_id }} ai-product-carousel__nav--prev-{{ ai_gen_id }}"
            aria-label="Previous product"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>

          <button
            class="ai-product-carousel__nav-{{ ai_gen_id }} ai-product-carousel__nav--next-{{ ai_gen_id }}"
            aria-label="Next product"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        {% endif %}
      </div>

      {% if products_to_show > 1 %}
        <div class="ai-product-carousel__dots-{{ ai_gen_id }}">
          {% for i in (1..products_to_show) %}
            <button
              class="ai-product-carousel__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
              data-index="{{ forloop.index0 }}"
            ></button>
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div class="ai-product-carousel__empty-{{ ai_gen_id }}">
        Select a collection to display products
      </div>
    {% endif %}
  </div>
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-product-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-product-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-product-carousel__nav--prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-product-carousel__nav--next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-product-carousel__dot-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        if (this.slides.length <= 1) return;

        this.setupEventListeners();

        if (this.autoplay) {
          this.startAutoplay();
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevious());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNext());
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            this.goToSlide(index);
          });
        });
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      goToNext() {
        this.currentIndex = (this.currentIndex + 1) % this.slides.length;
        this.updateCarousel();
      }

      goToPrevious() {
        this.currentIndex = (this.currentIndex - 1 + this.slides.length) % this.slides.length;
        this.updateCarousel();
      }

      updateCarousel() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        if (!this.autoplay || this.slides.length <= 1) return;

        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.goToNext();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product carousel",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Number of products",
      "default": 6
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to cart"
    },
    {
      "type": "header",
      "content": "Carousel settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable auto-scroll",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Auto-scroll speed",
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 500,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 500
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#eff0f5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#4770db"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#4770db"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_hover_background",
      "label": "Arrow hover background",
      "default": "#4770db"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#0e1b4d"
